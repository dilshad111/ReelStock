[req]
default_bits = 2048
prompt = no
default_md = sha256
distinguished_name = dn
x509_extensions = v3_req

[dn]
C = PK
ST = Punjab
L = Lahore
O = Quality Cartons
OU = IT
CN = 192.168.10.47

[v3_req]
keyUsage = keyEncipherment, dataEncipherment
extendedKeyUsage = serverAuth
subjectAltName = @alt_names

[alt_names]
IP.1 = 192.168.10.47
DNS.1 = localhost
